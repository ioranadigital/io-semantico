{
  "name": "io-monorepo",
  "version": "0.1.0",
  "type": "module",
  "description": "Iorana Digital Monorepo - Tools, internal apps, and client projects",
  "private": true,
  "scripts": {
    "install": "pnpm install",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r --parallel build",
    "test": "pnpm -r --parallel test",
    "lint": "pnpm -r --parallel lint",
    "format": "pnpm -r --parallel format",
    "type-check": "tsc --noEmit -p app/interno/ioranaseo/tsconfig.json",
    "clean": "pnpm -r --parallel clean",
    "clean:all": "pnpm clean && rm -rf node_modules pnpm-lock.yaml",
    "lib:dev": "pnpm --filter @iorana/lib dev",
    "semantico:dev": "pnpm --filter @iorana/io-semantico dev",
    "design:dev": "pnpm --filter @iorana/io-design dev",
    "iorana-next:dev": "pnpm --filter iorana-next dev",
    "ws:list": "pnpm ls -r --depth 0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  }
}
